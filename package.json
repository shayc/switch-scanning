{
  "name": "@shayc/switch-scanning",
  "version": "0.1.0",
  "description": "A small, serious switch-scanning library: a framework-agnostic scanning engine with React bindings.",
  "type": "module",
  "license": "MIT",
  "author": "Shay Cojocaru <shayc@outlook.com>",
  "homepage": "https://github.com/shayc/switch-scanning#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shayc/switch-scanning.git"
  },
  "bugs": {
    "url": "https://github.com/shayc/switch-scanning/issues"
  },
  "keywords": [
    "switch-scanning",
    "switch-access",
    "accessibility",
    "aac",
    "a11y",
    "react",
    "scanning"
  ],
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./core/testing": {
      "types": "./dist/core/testing/index.d.ts",
      "import": "./dist/core/testing/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/react/index.d.ts",
  "module": "./dist/react/index.js",
  "scripts": {
    "dev": "vite",
    "demo:build": "vite build --config vite.demo.config.ts",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "test:watch": "vitest",
    "publint": "publint",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "bundle:size": "node scripts/check-bundle-size.mjs",
    "changeset": "changeset",
    "version": "changeset version && npm install --package-lock-only",
    "release": "changeset publish",
    "prepublishOnly": "npm run build && npm run publint"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
